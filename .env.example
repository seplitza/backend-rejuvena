# Server Configuration
PORT=9527
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rejuvena

# Security
JWT_SECRET=your-secret-key-here

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Payment (Alfabank)
ALFABANK_USERNAME=your-username
ALFABANK_PASSWORD=your-password
ALFABANK_API_URL=https://payment.alfabank.ru/payment/rest
ALFABANK_RETURN_URL=https://your-domain.com/payment/success
ALFABANK_FAIL_URL=https://your-domain.com/payment/fail

# Frontend URL
FRONTEND_URL=https://your-frontend-domain.com

# Email Service (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@your-domain.com

# Wildberries Marketplace API
WB_API_TOKEN=your-wb-api-token
WB_SELLER_ID=your-seller-id

# DeepSeek AI API (for product descriptions)
DEEPSEEK_API_KEY=your-deepseek-api-key

# Legacy API Token (for migration)
OLD_API_TOKEN=your-old-api-token
